# Receptra — environment variable template.
# Copy to .env (gitignored) and adjust for your machine.

# --- Host paths ---
# Where model weights live on the host. Mounted read-only into backend container as /models.
MODEL_DIR=${HOME}/.receptra/models

# --- Ollama (runs NATIVELY on host, not in Docker — Metal GPU passthrough is unsupported) ---
OLLAMA_HOST=http://host.docker.internal:11434

# --- ChromaDB (runs in docker compose) ---
CHROMA_HOST=http://chromadb:8000
CHROMA_PORT=8000

# --- Service ports exposed on localhost ---
BACKEND_PORT=8080
FRONTEND_PORT=5173

# --- DictaLM quantization (Q5_K_M for 32GB Macs, Q4_K_M for 16GB Macs) ---
DICTALM_QUANT=Q4_K_M

# --- Log level ---
RECEPTRA_LOG_LEVEL=INFO

# --- Phase 2 STT (Hebrew streaming) — defaults locked by RESEARCH §Recommended
#     Dependencies + 02-01-SPIKE-RESULTS.md (partial_interval_decision). ---

# Subdirectory under MODEL_DIR holding the CT2 checkpoint (RESEARCH §1).
RECEPTRA_WHISPER_MODEL_SUBDIR=whisper-turbo-ct2

# CT2 compute type. int8 is the Apple Silicon default (RESEARCH §7); int8_float32
# fallback is only for rare ARM SIMD issues.
RECEPTRA_WHISPER_COMPUTE_TYPE=int8

# CT2 CPU thread count (RESEARCH §7 — 4 is optimal on M2 performance cores).
RECEPTRA_WHISPER_CPU_THREADS=4

# Local-only SQLite audit log (INT-05). Path is relative to the backend CWD.
RECEPTRA_AUDIT_DB_PATH=./data/audit.sqlite

# Partial-transcript emission interval in ms. 700 is the 02-01 provisional lock
# (UNMEASURED path); Plan 02-06 replaces this after M2 reference measurement.
RECEPTRA_STT_PARTIAL_INTERVAL_MS=700

# Silero VAD thresholds (RESEARCH §8).
RECEPTRA_VAD_THRESHOLD=0.5
RECEPTRA_VAD_MIN_SILENCE_MS=300
RECEPTRA_VAD_SPEECH_PAD_MS=200
