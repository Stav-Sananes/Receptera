# Receptra — environment variable template.
# Copy to .env (gitignored) and adjust for your machine.

# --- Host paths ---
# Where model weights live on the host. Mounted read-only into backend container as /models.
MODEL_DIR=${HOME}/.receptra/models

# --- Ollama (runs NATIVELY on host, not in Docker — Metal GPU passthrough is unsupported) ---
OLLAMA_HOST=http://host.docker.internal:11434

# --- ChromaDB (runs in docker compose) ---
CHROMA_HOST=http://chromadb:8000
CHROMA_PORT=8000

# --- Service ports exposed on localhost ---
BACKEND_PORT=8080
FRONTEND_PORT=5173

# --- DictaLM quantization (Q5_K_M for 32GB Macs, Q4_K_M for 16GB Macs) ---
DICTALM_QUANT=Q4_K_M

# --- Log level ---
RECEPTRA_LOG_LEVEL=INFO
