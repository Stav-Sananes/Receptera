# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# Node
node_modules/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# Env files — NEVER commit real secrets
.env
.env.local
.env.*.local

# Model weights (mounted via volume from ~/.receptra/models/; never committed)
*.bin
*.safetensors
*.ct2
*.gguf
*.pt
*.pth
models/

# User knowledge base (per-deployment data)
knowledge/*
!knowledge/.gitkeep
!knowledge/sample/
!knowledge/sample/**

# Docker runtime data — host-bind volume targets. Plan 02-06 reserves
# ./data/ as the SQLite audit-log mount point (./data:/app/data:rw in
# docker-compose.yml). All contents are local + PII-bearing → never
# committed; the .gitkeep stub is the one exception so the dir survives
# fresh clones before `make up` has run.
data/*
!data/.gitkeep
# Catch test-time side effects that escape the volume contract: tests run
# from ``cd backend`` resolve ``./data/audit.sqlite`` under backend/data/.
# Always ignore — the canonical persistence is at the repo-root data/.
backend/data/
.receptra/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# OS
Thumbs.db

# Logs
*.log
logs/
